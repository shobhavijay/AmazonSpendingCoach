# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── CSV input paths ───────────────────────────────────────────────────────────
# Set these to point to wherever your Amazon export files live.
# Defaults (used if not set) point to the sibling ../files/ directory.
TRANSACTIONS_CSV=../files/Order_history_4.csv
CATEGORIZED_CSV=../files/Order_history_4_categorized.csv
RETURNS_CSV=../files/Refund_Details_4.csv
CART_CSV=../files/Cart History.csv

# ── Output ────────────────────────────────────────────────────────────────────
OUTPUT_DIR=output
REPORT_FILENAME=report_v4.md

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_DATA_INGESTION=true
ENABLE_CATEGORY_CLASSIFIER=true
ENABLE_IMPULSE_DETECTOR=true
ENABLE_CART_ANALYZER=true
ENABLE_OUTPUT_FILE=true

# ── Spending forecast (optional — requires extra deps) ────────────────────────
# pip install ".[forecast-prophet]"  or  pip install ".[forecast-arima]"
ENABLE_SPENDING_FORECAST=false
FORECAST_MODEL=prophet

# ── Debug / observability ─────────────────────────────────────────────────────
ENABLE_DEBUG_MODE=false
LOG_FILENAME=agent.log

# ── LangSmith tracing (optional) ─────────────────────────────────────────────
# LANGSMITH_API_KEY=your-langsmith-api-key-here
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_PROJECT=spending-coach
